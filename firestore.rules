rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: settings
    // Document ID: config
    // Fields:
    //   - name, slogan, identity, about, etc. (SiteConfig)
    //
    // Collection: projects
    // Document ID: {projectId}
    // Fields:
    //   - id, title, subtitle, contentBlocks, etc. (Project)
    //
    // Collection: archive
    // Document ID: {itemId}
    // Fields:
    //   - id, year, category, title, details (ArchiveItem)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "juon77911@gmail.com" && request.auth.token.email_verified == true);
    }

    // Site Config
    match /settings/config {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Projects
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Archive
    match /archive/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
