{
  "entities": {
    "SiteConfig": {
      "title": "Site Configuration",
      "description": "General settings for the portfolio site",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slogan": { "type": "string" },
        "identity": { "type": "string" },
        "about": { "type": "string" },
        "aboutImages": { "type": "array", "items": { "type": "string" } },
        "education": { "type": "array", "items": { "type": "string" } },
        "experience": { "type": "array", "items": { "type": "string" } },
        "careerHighlights": { "type": "array", "items": { "type": "string" } },
        "accentColor": { "type": "string" },
        "secondaryColor": { "type": "string" },
        "fontFamily": { "type": "string" },
        "role": { "type": "string" },
        "linkedin": { "type": "string" },
        "email": { "type": "string" },
        "resumeUrl": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "fontSizes": {
          "type": "object",
          "properties": {
            "slogan": { "type": "number" },
            "body": { "type": "number" },
            "heading": { "type": "number" },
            "projectLineHeight": { "type": "number" }
          }
        },
        "projectLabels": {
          "type": "object",
          "properties": {
            "problem": { "type": "string" },
            "approach": { "type": "string" },
            "insights": { "type": "string" },
            "impact": { "type": "string" },
            "contribution": { "type": "string" }
          }
        },
        "sectionDescriptions": {
          "type": "object",
          "properties": {
            "about": { "type": "string" },
            "projects": { "type": "string" },
            "archive": { "type": "string" }
          }
        },
        "adminPassword": { "type": "string" }
      }
    },
    "Project": {
      "title": "Project",
      "description": "A portfolio project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "description": { "type": "string" },
        "about": { "type": "string" },
        "client": { "type": "string" },
        "services": { "type": "string" },
        "liveUrl": { "type": "string" },
        "date": { "type": "string" },
        "contentBlocks": { "type": "array", "items": { "type": "object" } },
        "visibleSections": { "type": "object" },
        "metrics": { "type": "string" },
        "tools": { "type": "array", "items": { "type": "string" } },
        "imageFilter": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "mainImage": { "type": "string" }
      }
    },
    "ArchiveItem": {
      "title": "Archive Item",
      "description": "A career archive entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "year": { "type": "string" },
        "category": { "type": "string" },
        "title": { "type": "string" },
        "details": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "firestore": {
    "/settings/config": {
      "schema": "SiteConfig",
      "description": "Global site configuration"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Individual project documents"
    },
    "/archive/{itemId}": {
      "schema": "ArchiveItem",
      "description": "Individual archive items"
    }
  }
}
