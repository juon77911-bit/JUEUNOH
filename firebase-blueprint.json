{
  "entities": {
    "SiteConfig": {
      "title": "Site Configuration",
      "description": "Global settings for the portfolio site",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slogan": { "type": "string" },
        "identity": { "type": "string" },
        "about": { "type": "string" },
        "aboutImages": { "type": "array", "items": { "type": "string" } },
        "education": { "type": "array", "items": { "type": "string" } },
        "experience": { "type": "array", "items": { "type": "string" } },
        "careerHighlights": { "type": "array", "items": { "type": "string" } },
        "accentColor": { "type": "string" },
        "secondaryColor": { "type": "string" },
        "fontFamily": { "type": "string" },
        "role": { "type": "string" },
        "linkedin": { "type": "string" },
        "email": { "type": "string" },
        "resumeUrl": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "fontSizes": { "type": "object" },
        "projectLabels": { "type": "object" },
        "sectionDescriptions": { "type": "object" },
        "adminPassword": { "type": "string" }
      }
    },
    "Project": {
      "title": "Project",
      "description": "A portfolio project item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string" },
        "contentBlocks": { "type": "array" },
        "visibleSections": { "type": "object" },
        "images": { "type": "array", "items": { "type": "string" } }
      }
    },
    "ArchiveItem": {
      "title": "Archive Item",
      "description": "A career archive item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "year": { "type": "string" },
        "category": { "type": "string" },
        "title": { "type": "string" },
        "details": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "firestore": {
    "/settings/config": {
      "schema": "SiteConfig",
      "description": "The site configuration document"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Individual project documents"
    },
    "/archive/{archiveId}": {
      "schema": "ArchiveItem",
      "description": "Individual archive item documents"
    }
  }
}
